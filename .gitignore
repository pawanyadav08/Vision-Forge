# ── VisionForge AI Monorepo Gitignore ──

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/

# System files
*.log
.DS_Store
Thumbs.db

# ── Backend specific ──
visionforge-backend/target/
visionforge-backend/!.mvn/wrapper/maven-wrapper.jar
visionforge-backend/build/

# ── Frontend specific ──
visionforge-frontend/node_modules/
visionforge-frontend/dist/
visionforge-frontend/dist-ssr/
visionforge-frontend/*.local
visionforge-frontend/.eslintcache

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
